# Database Configuration
E5RENEW_DATABASE_ENGINE=mysql
# MySQL DSN example:
E5RENEW_DATABASE_DSN=user:password@tcp(localhost:3306)/e5renew?parseTime=true
# Postgres DSN example (Docker mapped 15432):
# E5RENEW_DATABASE_ENGINE=postgres
# E5RENEW_DATABASE_DSN=postgres://postgres:postgres@localhost:15432/e5renew?sslmode=disable

# Azure AD Configuration
E5RENEW_AZUREAD_TENANT=your-tenant-id
E5RENEW_AZUREAD_CLIENTID=your-client-id
E5RENEW_AZUREAD_CLIENTSECRET=your-client-secret
E5RENEW_AZUREAD_REDIRECTURL=http://localhost:8080/oauth2/callback

# Server Configuration
E5RENEW_LISTEN=:8080

# Debug Mode (set to true to show tokens in UI)
E5RENEW_DEBUG=false

# OpenTelemetry Configuration
E5RENEW_OTEL_SERVICE_NAME=e5renew
E5RENEW_OTEL_SERVICE_VERSION=v0.1.0
E5RENEW_OTEL_ENVIRONMENT=development
E5RENEW_OTEL_OTLP_ENDPOINT=http://localhost:4318
E5RENEW_OTEL_ENABLE_TRACING=true
E5RENEW_OTEL_ENABLE_METRICS=true
E5RENEW_OTEL_ENABLE_STDOUT=false